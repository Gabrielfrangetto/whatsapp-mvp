generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AgentRole @default(AGENT)
  avatarColor  String    @default("#25D366")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  themeColor String? @default("#075E54")
  themeMode  String? @default("light")
  avatarUrl  String?

  conversations Conversation[] @relation("AssignedAgent")
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Contact {
  id         String   @id @default(uuid())
  phone      String   @unique
  name       String?
  profilePic String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id            String     @id @default(uuid())
  contactId     String
  contact       Contact    @relation(fields: [contactId], references: [id])
  status        ConvStatus @default(OPEN)
  assignedToId  String?
  assignedAgent Agent?     @relation("AssignedAgent", fields: [assignedToId], references: [id])
  lastMessage   String?
  lastMessageAt DateTime?
  unreadCount   Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  messages Message[]
}

model Message {
  id             String      @id @default(uuid())
  waMessageId    String?     @unique
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  direction      Direction
  type           MessageType @default(TEXT)
  content        String
  mediaUrl       String?
  status         MsgStatus   @default(SENT)
  sentByAgentId  String?
  timestamp      DateTime    @default(now())
  createdAt      DateTime    @default(now())
}

model MessageTemplate {
  id        String         @id @default(uuid())
  metaId    String         @unique
  name      String
  status    TemplateStatus @default(PENDING)
  category  String
  language  String         @default("pt_BR")
  body      String
  header    String?
  footer    String?
  variables String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Motivos de finalização cadastráveis pelo admin
model ResolutionReason {
  id        String   @id @default(uuid())
  label     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AgentRole {
  ADMIN
  AGENT
}

enum ConvStatus {
  OPEN
  PENDING
  RESOLVED
}

enum Direction {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  INTERNAL
}

enum MsgStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
}
