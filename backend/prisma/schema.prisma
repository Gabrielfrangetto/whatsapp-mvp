generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String            @id @default(uuid())
  name         String
  email        String            @unique
  passwordHash String
  role         AgentRole         @default(AGENT)
  avatarColor  String            @default("#25D366")
  isActive     Boolean           @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  themeColor   String?           @default("#075E54")
  themeMode    String?           @default("light")
  avatarUrl    String?
  onlineStatus AgentOnlineStatus @default(OFFLINE)
  workSchedule Json?

  conversations    Conversation[]    @relation("AssignedAgent")
  refreshTokens    RefreshToken[]
  conversationPins ConversationPin[]
  stickerFavorites StickerFavorite[]
  statusLogs       AgentStatusLog[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Contact {
  id         String   @id @default(uuid())
  phone      String   @unique
  name       String?
  profilePic String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  conversations  Conversation[]
  pipedriveDeals PipedriveDeal[]
  calls          Call[]
}

model Conversation {
  id                   String     @id @default(uuid())
  contactId            String
  contact              Contact    @relation(fields: [contactId], references: [id])
  status               ConvStatus @default(OPEN)
  assignedToId         String?
  assignedAgent        Agent?     @relation("AssignedAgent", fields: [assignedToId], references: [id])
  lastMessage          String?
  lastMessageAt        DateTime?
  lastMessageDirection String?
  unreadCount          Int        @default(0)
  openedAt             DateTime?
  resolvedAt           DateTime?
  resolvedByAgentId    String?
  assignmentSource     String?
  firstResponseAt      DateTime?
  reopenCount          Int        @default(0)
  transferredFromId    String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  messages Message[]
  pins     ConversationPin[]
}

model Message {
  id                String       @id @default(uuid())
  waMessageId       String?      @unique
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  direction         Direction
  type              MessageType  @default(TEXT)
  content           String
  mediaUrl          String?
  status            MsgStatus    @default(SENT)
  sentByAgentId     String?
  timestamp         DateTime     @default(now())
  createdAt         DateTime     @default(now())
  reactions         Json?
  quotedMessageId   String?
  quotedMessage     Message?     @relation("MessageQuotes", fields: [quotedMessageId], references: [id])
  quotedBy          Message[]    @relation("MessageQuotes")
  quotedWaMessageId String?
}

model MessageTemplate {
  id        String         @id @default(uuid())
  metaId    String         @unique
  name      String
  status    TemplateStatus @default(PENDING)
  category  String
  language  String         @default("pt_BR")
  body      String
  header    String?
  footer    String?
  variables String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ConversationPin {
  agentId        String
  conversationId String
  createdAt      DateTime @default(now())

  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([agentId, conversationId])
}

model Sticker {
  id        String   @id @default(uuid())
  name      String
  url       String
  createdAt DateTime @default(now())
}

model StickerFavorite {
  id         String    @id @default(uuid())
  agentId    String
  mediaUrl   String
  name       String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, mediaUrl])
}

// Motivos de finalização cadastráveis pelo admin
model ResolutionReason {
  id        String   @id @default(uuid())
  label     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentStatusLog {
  id        String            @id @default(uuid())
  agentId   String
  agent     Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status    AgentOnlineStatus
  startedAt DateTime          @default(now())
  endedAt   DateTime?

  @@index([agentId, startedAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Funil de vendas (Pipedrive) ─────────────────────────────────────────────

model PipedriveStage {
  id         Int      @id // id do estágio no Pipedrive
  pipelineId Int
  name       String
  orderNr    Int
  updatedAt  DateTime @updatedAt
}

model PipedriveDeal {
  id                String              @id @default(uuid())
  pipedriveDealId   Int                 @unique
  pipedrivePersonId Int?
  contactId         String?
  contact           Contact?            @relation(fields: [contactId], references: [id])
  title             String
  value             Float?
  currency          String?
  stageId           Int
  stageName         String
  status            PipedriveDealStatus @default(OPEN)
  wonAt             DateTime?
  lostAt            DateTime?
  lostReason        String?
  pipedriveAddedAt  DateTime
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  stageLogs PipedriveDealStageLog[]

  @@index([status])
  @@index([contactId])
}

model PipedriveDealStageLog {
  id        String        @id @default(uuid())
  dealId    String
  deal      PipedriveDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stageId   Int
  stageName String
  enteredAt DateTime
  exitedAt  DateTime?

  @@index([dealId, enteredAt])
  @@index([stageId, enteredAt])
}

enum PipedriveDealStatus {
  OPEN
  WON
  LOST
}

enum AgentRole {
  ADMIN
  AGENT
}

enum AgentOnlineStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum ConvStatus {
  OPEN
  PENDING
  RESOLVED
}

enum Direction {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum MessageType {
  TEXT
  IMAGE
  STICKER
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
  INTERNAL
}

enum MsgStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Chamadas de voz (WhatsApp Calling API) ──────────────────────────────────

model Call {
  id              String     @id @default(uuid())
  waCallId        String     @unique // id da chamada no WhatsApp
  contactId       String?
  contact         Contact?   @relation(fields: [contactId], references: [id])
  phone           String
  status          CallStatus @default(RINGING)
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  rawEvent        Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([contactId])
  @@index([startedAt])
}

enum CallStatus {
  RINGING
  ANSWERED
  MISSED
  REJECTED
}
